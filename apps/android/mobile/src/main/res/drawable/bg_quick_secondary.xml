<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#E9E2D1" />
            <stroke android:width="1dp" android:color="#D1C3A8" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="#FBF7ED" />
            <stroke android:width="1dp" android:color="#E2D7BE" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
